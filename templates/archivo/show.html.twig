<!DOCTYPE html>

<title>Archivo</title>

{% block body %}
    <h1>Archivo</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ archivo.id }}</td>
            </tr>
            <tr>
                <th>NombreOriginal</th>
                <td>{{ archivo.nombreOriginal }}</td>
            </tr>
            <tr>
                <th>NombreFisico</th>
                <td>{{ archivo.nombreFisico }}</td>
            </tr>
            <tr>
                <th>Ruta</th>
                <td>{{ archivo.ruta }}</td>
            </tr>
            <tr>
                <th>MimeType</th>
                <td>{{ archivo.mimeType }}</td>
            </tr>
            <tr>
                <th>Extension</th>
                <td>{{ archivo.extension }}</td>
            </tr>
            <tr>
                <th>Tamano</th>
                <td>{{ archivo.tamano }}</td>
            </tr>
            <tr>
                <th>Tipo</th>
                <td>{{ archivo.tipo }}</td>
            </tr>
            <tr>
                <th>Ancho</th>
                <td>{{ archivo.ancho }}</td>
            </tr>
            <tr>
                <th>Alto</th>
                <td>{{ archivo.alto }}</td>
            </tr>
            <tr>
                <th>Duracion</th>
                <td>{{ archivo.duracion }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ archivo.createdAt ? archivo.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ archivo.updatedAt ? archivo.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Activo</th>
                <td>{{ archivo.activo ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_archivo_index') }}">back to list</a>

    <a href="{{ path('app_archivo_edit', {'id': archivo.id}) }}">edit</a>

    {{ include('archivo/_delete_form.html.twig') }}
{% endblock %}

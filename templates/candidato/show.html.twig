<!DOCTYPE html>

<title>Candidato</title>

{% block body %}
    <h1>Candidato</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ candidato.id }}</td>
            </tr>
            <tr>
                <th>Nombre</th>
                <td>{{ candidato.nombre }}</td>
            </tr>
            <tr>
                <th>Apellido</th>
                <td>{{ candidato.apellido }}</td>
            </tr>
            <tr>
                <th>Foto</th>
                <td>{{ candidato.foto }}</td>
            </tr>
            <tr>
                <th>Descripcion</th>
                <td>{{ candidato.descripcion }}</td>
            </tr>
            <tr>
                <th>Activo</th>
                <td>{{ candidato.activo ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Orden</th>
                <td>{{ candidato.orden }}</td>
            </tr>
            <tr>
                <th>CantidadVotos</th>
                <td>{{ candidato.cantidadVotos }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ candidato.createdAt ? candidato.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ candidato.updatedAt ? candidato.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_candidato_index') }}">back to list</a>

    <a href="{{ path('app_candidato_edit', {'id': candidato.id}) }}">edit</a>

    {{ include('candidato/_delete_form.html.twig') }}
{% endblock %}

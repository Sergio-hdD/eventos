<!DOCTYPE html>

<title>Participante</title>

{% block body %}
    <h1>Participante</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ participante.id }}</td>
            </tr>
            <tr>
                <th>Rol</th>
                <td>{{ participante.rol }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ participante.createdAt ? participante.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ participante.updatedAt ? participante.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Activo</th>
                <td>{{ participante.activo ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_participante_index') }}">back to list</a>

    <a href="{{ path('app_participante_edit', {'id': participante.id}) }}">edit</a>

    {{ include('participante/_delete_form.html.twig') }}
{% endblock %}
